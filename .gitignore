# Secrets — NEVER commit the real key. Use .env.example as the template.
.env

# Generated project assets + state (large, user-specific, not source).
data/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# Throwaway verification scratch files
_verify*.py
_verify*.txt
_verify*.png
_run.log
_live_server.log
__pycache__/
*.pyc

# User vault — contains per-user API keys, NEVER commit
vault.json
vault.json.bak*
users.json
codes.json

# --- Windows app build artifacts (large, regenerable) ---
build/
dist/
*.spec.bak
ffmpeg_bin/
# installer_output/ is NOT gitignored — the final Setup.exe is pushed (user-requested).
# *.exe is NOT gitignored — same reason; the source *.exe artifacts in dist/ stay gitignored via the dist/ line above.

